{
  "name": "gbfr-sharecard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "*.{js,jsx,json,css,md}": "prettier --write"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.0.0",
    "prettier": "^3.9.0",
    "sharp": "^0.35.3",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@tanstack/react-router": "^1.170.18",
    "modern-screenshot": "^4.7.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
